{
  "manifest_version": 1,
  "name": "MC查服插件",
  "version": "1.0.0",
  "description": "我的世界服务器状态查询插件，支持查询在线人数、延迟、TPS、在线玩家等信息",
  "author": {
    "name": "月白清风",
    "url": "https://github.com/yuebaiqingfeng"
  },
  "license": "GPL-3.0",
  "host_application": {
    "min_version": "0.12.2"
  },
  "homepage_url": "https://github.com/yuebaiqingfeng/MinecraftServerStatus",
  "repository_url": "https://github.com/yuebaiqingfeng/MinecraftServerStatus",
  "keywords": [
    "minecraft",
    "server",
    "status",
    "tps",
    "rcon",
    "query"
  ],
  "categories": [
    "Tools",
    "Utility"
  ],
  "default_locale": "zh-CN",
  "locales_path": "_locales",
  "plugin_info": {
    "is_built_in": false,
    "plugin_type": "server_status",
    "components": [
      {
        "type": "command",
        "name": "minecraft_server_status",
        "description": "查询我的世界服务器状态",
        "activation_modes": [
          "keyword"
        ],
        "keywords": [
          "查服",
          "服务器状态",
          "信息"
        ]
      }
    ],
    "features": [
      "服务器基础状态查询：在线人数、延迟、版本",
      "支持RCON获取服务器TPS",
      "在线玩家列表查询",
      "查询缓存，避免频繁请求服务器",
      "服务器离线友好提示",
      "兼容所有版本的mcstatus",
      "多命令触发，使用更方便"
    ]
  },
  "id": "yuebaiqingfeng.MinecraftServerStatus"
}
